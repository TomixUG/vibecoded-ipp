<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26" description="nova instance tridy Foo, foo">
  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">
        <assign order="1">
          <var name="stringIWannaPrint"/>
          <expr>
            <literal class="String" value="this is the string i wanna print\n"/>
          </expr>
        </assign>
        <assign order="2">
          <var name="foo"/>
          <expr>
            <send selector="new">
              <expr>
                <literal class="class" value="Foo"/>
              </expr>
            </send>
          </expr>
        </assign>
        <assign order="3">
          <var name="b"/>
          <expr>
            <send selector="myPrint:">
              <expr>
                <var name="foo"/>
              </expr>
              <arg order="1">
                <expr>
                  <var name="stringIWannaPrint"/>
                </expr>
              </arg>
            </send>
          </expr>
        </assign>
        <assign order="4">
          <var name="bar"/>
          <expr>
            <send selector="new">
              <expr>
                <literal class="class" value="Bar"/>
              </expr>
            </send>
          </expr>
        </assign>
        <assign order="5">
          <var name="c"/>
          <expr>
            <send selector="myPrint:">
              <expr>
                <var name="bar"/>
              </expr>
              <arg order="1">
                <expr>
                  <literal class="String" value="bar string\n"/>
                </expr>
              </arg>
            </send>
          </expr>
        </assign>
        <assign order="6">
          <var name="d"/>
          <expr>
            <send selector="quack">
              <expr>
                <var name="bar"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
  <class name="Foo" parent="Object">
    <method selector="myPrint:">
      <block arity="1">
        <parameter order="1" name="myStr"/>
        <assign order="1">
          <var name="a"/>
          <expr>
            <send selector="print">
              <expr>
                <var name="myStr"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
  <class name="Bar" parent="Foo">
    <method selector="quack">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="print">
              <expr>
                <literal class="String" value="quack!"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
</program>
